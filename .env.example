# Self-Healing RAG Engine Configuration
# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database (Neon PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://user:password@your-neon-endpoint.neon.tech:5432/your_db?sslmode=require

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu  # or cuda, mps

# Reranker Model
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# LLM Models
GENERATION_MODEL=claude-sonnet-4-20250514
AGENT_MODEL=claude-haiku-4-20250514

# Retrieval Settings
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.5

# Confidence Thresholds
CONFIDENCE_HIGH_THRESHOLD=0.75
CONFIDENCE_LOW_THRESHOLD=0.45
MAX_CORRECTION_LOOPS=2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
