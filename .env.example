# Self-Healing RAG Engine Configuration
# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database (Neon PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://user:password@your-neon-endpoint.neon.tech:5432/your_db?sslmode=require

# Anthropic API (required for agents)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Google API (required for generation)
GOOGLE_API_KEY=your-google-api-key-here

# Mercury 2 API (optional - 10x faster inference)
# Get your API key at: https://platform.inceptionlabs.ai
# Mercury 2 uses diffusion-based generation for ~1000 tokens/second
# MERCURY_API_KEY=your-mercury-api-key-here
# USE_MERCURY_FOR_AGENTS=false
# USE_MERCURY_FOR_GENERATION=false
# MERCURY_REASONING_EFFORT=low  # low=faster, high=better quality

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu  # or cuda, mps

# Reranker Model
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# LLM Models
GENERATION_MODEL=claude-sonnet-4-20250514
AGENT_MODEL=claude-haiku-4-20250514

# Retrieval Settings
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.5

# Confidence Thresholds
CONFIDENCE_HIGH_THRESHOLD=0.75
CONFIDENCE_LOW_THRESHOLD=0.45
MAX_CORRECTION_LOOPS=2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
